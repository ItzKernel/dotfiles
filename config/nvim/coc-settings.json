{
    "suggest.noselect": true,
    "languageserver": {
        "c": {
            "command": "clangd",
            "trace.server": "verbose",
            "filetypes": ["c", "h"]
        },
        "cpp": {
            "command": "clangd",
            "trace.server": "verbose",
            "filetypes": ["cpp", "hpp"]
        }
    }
}
